{
  "extends": "./base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["../../../src/**/*.ts", "../../../test/**/*.ts", "../../../test-d/**/*.ts", "../test/vitest.config.ts", "../test/vitest.shims.d.ts"],
  "exclude": [
    "../../../dist",
    "../../../node_modules",
    "../../../.tsbuildinfo",
    "../../../.bench",
    "../../../.benchmark/current",
    "../../../.benchmark/previous",
    "../../../.benchmark/comparison",
    "../../../.benchmark/smoke",
    "../../../coverage"
  ]
}
