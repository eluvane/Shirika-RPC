{
  "singleQuote": true,
  "semi": true,
  "trailingComma": "all",
  "printWidth": 160,
  "tabWidth": 4,
  "overrides": [
    {
      "files": ["*.json", "*.yml", "*.yaml", "*.html"],
      "options": {
        "tabWidth": 2
      }
    },
    {
      "files": "*.jsonc",
      "options": {
        "tabWidth": 2,
        "trailingComma": "none"
      }
    },
    {
      "files": "*.md",
      "options": {
        "proseWrap": "preserve",
        "tabWidth": 2
      }
    }
  ]
}
